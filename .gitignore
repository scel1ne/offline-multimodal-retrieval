# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# macOS / CocoaPods
/macos/Pods/
/macos/Flutter/ephemeral/
/macos/Flutter/Flutter.framework/

# Built distributable app bundle
/dist/

# Local Flutter / Pub caches (vendored, large, machine-specific)
/.tooling/
/.home/
/.pub-cache/
/.downloads/
/.flutter_releases_macos.json

# Local vector database scratch data
/.chroma-test/

# Logs
*.log

# CocoaPods lockfile (regenerated locally)
/macos/Pods/Manifest.lock
/macos/Runner.xcworkspace/xcuserdata/
/macos/Runner.xcodeproj/xcuserdata/
/macos/Runner.xcodeproj/project.xcworkspace/xcuserdata/

# Large model files (downloaded separately, see docs/model_assets_required.md)
/assets/models/*.tflite
/assets/models/*.mlpackage/
/assets/models/*.mlmodel
/assets/models/*.onnx
/assets/models/*.pt
/assets/models/*.pth
/assets/models/*.bin
